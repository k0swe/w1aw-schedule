rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{eventId}/original/{userId}/{fileName} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      function isApprovedForEvent() {
        let approval = firestore.get(
          /databases/(default)/documents/events/$(eventId)/approvals/$(request.auth.uid));
        return approval != null && approval.data.status == 'Approved';
      }

      function isAdminForEvent() {
        let event = firestore.get(
          /databases/(default)/documents/events/$(eventId));
        return event != null
          && event.data.admins != null
          && request.auth.uid in event.data.admins;
      }

      // Only the file owner (an approved operator for this event) may upload
      allow write: if isOwner()
        && isApprovedForEvent();

      // Owners may read/list their own uploads; event admins may read any upload
      allow read: if isOwner() || isAdminForEvent();
    }
  }
}

{
  "name": "w1aw-schedule-functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint .",
    "logs": "firebase functions:log",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "test": "firebase emulators:exec --only firestore 'npm run test:unit'",
    "test:unit": "npm run build && mocha --reporter spec ./build/ --recursive"
  },
  "engines": {
    "node": "24"
  },
  "main": "build/src/index.js",
  "dependencies": {
    "adif-parser-ts": "^0.7.3",
    "cors": "^2.8.6",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "ical-generator": "^11.0.0",
    "jszip": "^3.10.1",
    "uuid-by-string": "^4.0.0",
    "w1aw-schedule-shared": "file:../shared"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.5.0",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "private": true
}
